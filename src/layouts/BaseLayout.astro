---
import { siteConfig } from '../data/site.ts';

interface Props {
  title?: string;
  description?: string;
  canonicalUrl?: string;
  ogImage?: string;
  pageType?: 'website' | 'article';
}

const {
  title = siteConfig.name,
  description = `${siteConfig.name} — ${siteConfig.tagline}`,
  canonicalUrl,
  ogImage,
  pageType = 'website',
} = Astro.props;

const siteUrl = 'https://CLIENT_DOMAIN_PLACEHOLDER';
const fullCanonical = canonicalUrl || new URL(Astro.url.pathname, siteUrl).href;
const fullOgImage = ogImage ? new URL(ogImage, siteUrl).href : '';

const currentPath = Astro.url.pathname;
const currentYear = new Date().getFullYear();
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="keywords" content="electrician, electrical services, Lafayette, LA, electrical repair, electrical installation" />
  <meta name="author" content={siteConfig.name} />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={fullCanonical} />

  <meta property="og:type" content={pageType} />
  <meta property="og:url" content={fullCanonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:site_name" content={siteConfig.name} />
  <meta property="og:locale" content="en_US" />
  <meta property="og:image" content={fullOgImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content={title} />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:url" content={fullCanonical} />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={fullOgImage} />

  <meta name="geo.region" content="US-LA" />
  <meta name="geo.placename" content="Lafayette" />

  <meta http-equiv="X-Frame-Options" content="SAMEORIGIN" />
  <meta http-equiv="X-Content-Type-Options" content="nosniff" />
  <meta http-equiv="X-SSP-Protection" content="1; mode=block" />
  <meta name="referrer" content="strict-origin-when-cross-origin" />
  <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' https://unpkg.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self'; frame-src 'self' https://unpkg.com; base-uri 'self'; form-action 'self'; frame-ancestors 'self'; object-src 'none'" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": siteConfig.name,
    "description": `${siteConfig.name} - Professional electrical services in Lafayette, LA`,
    "url": siteUrl,
    "telephone": siteConfig.phone,
    "email": siteConfig.email,
    "address": {
      "@type": "PostalAddress",
      "streetAddress": siteConfig.address,
      "addressLocality": "Lafayette",
      "addressRegion": "LA",
      "postalCode": "",
      "addressCountry": "US"
    },
    "openingHours": siteConfig.hours,
    "priceRange": "$$",
    "sameAs": Object.values(siteConfig.socials).filter(Boolean)
  })} />
</head>
<body class="min-h-screen flex flex-col">
  <a href="#main-content" class="skip-link">Skip to content</a>

  <header class="bg-primary text-white shadow-lg">
    <nav class="container mx-auto px-4 py-4" aria-label="Main navigation">
      <div class="flex items-center justify-between">
        <a href="/" class="text-2xl font-heading font-extrabold hover:opacity-90 transition-opacity">
          ⚡ {siteConfig.name}
        </a>

        <ul class="hidden md:flex items-center gap-8">
          <li>
            <a href="/" class={`font-semibold hover:text-secondary transition-colors ${currentPath === '/' ? 'text-secondary underline underline-offset-4' : ''}`}>
              Home
            </a>
          </li>
          <li>
            <a href="/about/" class={`font-semibold hover:text-secondary transition-colors ${currentPath === '/about/' ? 'text-secondary underline underline-offset-4' : ''}`}>
              About
            </a>
          </li>
          <li>
            <a href="/services/" class={`font-semibold hover:text-secondary transition-colors ${currentPath === '/services/' ? 'text-secondary underline underline-offset-4' : ''}`}>
              Services
            </a>
          </li>
          <li>
            <a href="/gallery/" class={`font-semibold hover:text-secondary transition-colors ${currentPath === '/gallery/' ? 'text-secondary underline underline-offset-4' : ''}`}>
              Gallery
            </a>
          </li>
          <li>
            <a href="/contact/" class="bg-secondary text-primary font-bold px-6 py-2 rounded-full hover:bg-white hover:scale-105 transition-all shadow-md">
              Contact
            </a>
          </li>
        </ul>

        <a href="/contact/" class="md:hidden bg-secondary text-primary font-bold px-4 py-2 rounded-full text-sm">
          Contact Us
        </a>
      </div>
    </nav>
  </header>

  <main id="main-content" class="flex-1">
    <slot />
  </main>

  <footer class="bg-primary-dark text-white">
    <div class="container mx-auto px-4 py-12">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <div>
          <h3 class="font-heading font-bold text-xl mb-4 flex items-center gap-2">
            ⚡ {siteConfig.name}
          </h3>
          <p class="text-white/80 text-sm mb-4">{siteConfig.tagline}</p>
          <p class="text-white/70 text-sm">{siteConfig.mission}</p>
        </div>

        <div>
          <h4 class="font-heading font-bold text-lg mb-4 text-secondary">Quick Links</h4>
          <ul class="space-y-2">
            <li><a href="/" class="text-white/80 hover:text-secondary transition-colors">Home</a></li>
            <li><a href="/about/" class="text-white/80 hover:text-secondary transition-colors">About Us</a></li>
            <li><a href="/services/" class="text-white/80 hover:text-secondary transition-colors">Our Services</a></li>
            <li><a href="/gallery/" class="text-white/80 hover:text-secondary transition-colors">Gallery</a></li>
            <li><a href="/contact/" class="text-white/80 hover:text-secondary transition-colors">Contact Us</a></li>
          </ul>
        </div>

        <div>
          <h4 class="font-heading font-bold text-lg mb-4 text-secondary">Contact Info</h4>
          <address class="not-italic text-white/80 space-y-2">
            <p>{siteConfig.address}</p>
            <p>📞 {siteConfig.phone}</p>
            <p>✉️ {siteConfig.email}</p>
            <p>🕐 {siteConfig.hours}</p>
          </address>
        </div>

        <div>
          <h4 class="font-heading font-bold text-lg mb-4 text-secondary">Service Area</h4>
          <p class="text-white/80 text-sm mb-4">Proudly serving {siteConfig.serviceArea} and surrounding areas since {siteConfig.yearFounded}.</p>
          <p class="text-white/60 text-xs mt-4">This is the official website of {siteConfig.name}. We will never ask for passwords or payment info via email.</p>
        </div>
      </div>

      <div class="border-t border-white/20 mt-8 pt-8 text-center text-white/60 text-sm">
        <p>© {currentYear} {siteConfig.name}. All rights reserved.</p>
      </div>
    </div>
  </footer>
</body>
</html>